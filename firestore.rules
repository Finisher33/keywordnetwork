rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "sangahan@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['id', 'name', 'courseId']) &&
             data.id is string && data.name is string && data.courseId is string;
    }

    function isValidCourse(data) {
      return data.keys().hasAll(['id', 'name']) &&
             data.id is string && data.name is string;
    }

    function isValidSession(data) {
      return data.keys().hasAll(['id', 'courseId', 'name', 'isActive']) &&
             data.id is string && data.courseId is string && data.name is string && data.isActive is bool;
    }

    function isValidInterest(data) {
      return data.keys().hasAll(['id', 'userId', 'type', 'keyword']) &&
             data.id is string && data.userId is string && data.type in ['giver', 'taker'] && data.keyword is string;
    }

    function isValidInsight(data) {
      return data.keys().hasAll(['id', 'userId', 'sessionId', 'keyword']) &&
             data.id is string && data.userId is string && data.sessionId is string && data.keyword is string;
    }

    function isValidPresetInterest(data) {
      return data.keys().hasAll(['id', 'keyword']) &&
             data.id is string && data.keyword is string;
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    // Users
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidUser(request.resource.data);
      allow update: if isAuthenticated() && (isOwner(userId) || isAdmin()) && isValidUser(request.resource.data);
      allow delete: if isAdmin();
    }

    // Courses
    match /courses/{courseId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Sessions
    match /sessions/{sessionId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Interests
    match /interests/{interestId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidInterest(request.resource.data);
      allow update: if isAuthenticated() && (request.auth.uid == resource.data.userId || isAdmin()) && isValidInterest(request.resource.data);
      allow delete: if isAuthenticated() && (request.auth.uid == resource.data.userId || isAdmin());
    }

    // User Insights
    match /userInsights/{insightId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidInsight(request.resource.data);
      allow update: if isAuthenticated() && (request.auth.uid == resource.data.userId || isAdmin() || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes']));
      allow delete: if isAuthenticated() && (request.auth.uid == resource.data.userId || isAdmin());
    }

    // Tea Time Requests
    match /teaTimeRequests/{requestId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.fromUserId || request.auth.uid == resource.data.toUserId || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.fromUserId == request.auth.uid;
      allow update: if isAuthenticated() && (request.auth.uid == resource.data.toUserId || request.auth.uid == resource.data.fromUserId || isAdmin());
      allow delete: if isAdmin();
    }

    // Canonical Terms
    match /canonicalTerms/{termId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin(); // Only admin should manage canonical terms
    }

    // Preset Interests
    match /presetInterests/{presetId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Legacy data doc (for migration cleanup)
    match /giveandtake/data {
      allow read, write: if isAdmin();
    }
  }
}
