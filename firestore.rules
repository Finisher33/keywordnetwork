rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['id', 'name', 'courseId']) &&
             data.id is string && data.name is string && data.courseId is string;
    }

    function isValidCourse(data) {
      return data.keys().hasAll(['id', 'name']) &&
             data.id is string && data.name is string;
    }

    function isValidSession(data) {
      return data.keys().hasAll(['id', 'courseId', 'name', 'isActive']) &&
             data.id is string && data.courseId is string &&
             data.name is string && data.isActive is bool;
    }

    function isValidInterest(data) {
      return data.keys().hasAll(['id', 'userId', 'type', 'keyword']) &&
             data.id is string && data.userId is string &&
             data.type in ['giver', 'taker'] && data.keyword is string;
    }

    function isValidInsight(data) {
      return data.keys().hasAll(['id', 'userId', 'sessionId', 'keyword']) &&
             data.id is string && data.userId is string &&
             data.sessionId is string && data.keyword is string;
    }

    function isValidPresetInterest(data) {
      return data.keys().hasAll(['id', 'keyword']) &&
             data.id is string && data.keyword is string;
    }

    // Users
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidUser(request.resource.data);
      allow update: if isAuthenticated() && isValidUser(request.resource.data);
      allow delete: if isAuthenticated();
    }

    // Courses
    match /courses/{courseId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // Sessions
    match /sessions/{sessionId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // Interests
    match /interests/{interestId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidInterest(request.resource.data);
      allow update: if isAuthenticated() && isValidInterest(request.resource.data);
      allow delete: if isAuthenticated();
    }

    // User Insights
    match /userInsights/{insightId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidInsight(request.resource.data);
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated();
    }

    // Tea Time Requests
    match /teaTimeRequests/{requestId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated();
    }

    // Canonical Terms
    match /canonicalTerms/{termId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // Preset Interests
    match /presetInterests/{presetId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // Legacy data doc
    match /giveandtake/data {
      allow read, write: if isAuthenticated();
    }
  }
}
